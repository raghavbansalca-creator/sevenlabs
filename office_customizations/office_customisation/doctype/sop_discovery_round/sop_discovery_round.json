  {"fieldname": "processing_error", "fieldtype": "Long Text", "label": "Processing error (latest)", "read_only": 1, "description": "Populated if the most recent Process Transcript run failed. Cleared on next successful run."},
  {"fieldname": "section_extras", "fieldtype": "Section Break", "label": "Extra observations from transcript", "collapsible": 1,
