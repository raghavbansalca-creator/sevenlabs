  {"fieldname": "extra_observations", "fieldtype": "Long Text", "label": "Extra observations (JSON)", "read_only": 1},
  {"fieldname": "section_notes",   "fieldtype": "Section Break", "label": "Notes & rationale", "collapsible": 1},
  {"fieldname": "free_text_notes", "fieldtype": "Long Text", "label": "Free-text meeting notes"},
  {"fieldname": "rationale",       "fieldtype": "Long Text", "label": "AI rationale for this round"}
