  {"fieldname": "round_date",      "fieldtype": "Date",      "label": "Date",      "in_list_view": 1, "columns": 2},
  {"fieldname": "conducted_by",    "fieldtype": "Link",      "label": "Conducted by", "options": "User", "in_list_view": 1, "columns": 3},
